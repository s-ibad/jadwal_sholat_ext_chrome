{
  "manifest_version": 3,
  "name": "Jadwal Sholat",
  "version": "1.0",
  "description": "Menampilkan jadwal sholat harian di popup ekstensi Chrome.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "geolocation",
    "notifications",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://nominatim.openstreetmap.org/*",
    "https://api.aladhan.com/*"
  ],
  "icons": {
    "128": "icon.png"
  }
}